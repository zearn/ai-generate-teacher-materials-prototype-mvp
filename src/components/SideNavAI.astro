---
/**
 * Sidenav (Figma 17730:1213) — 214px card. Mini Lesson (active) / Student
 * Materials / Sample Script (each with a 24px sparkle Button that swaps to a
 * refresh glyph once generated) / Problem Set "Coming Soon".
 *
 * This pass ships markup + all visual states + a minimal slider positioner that
 * parks the purple highlight under the active item on load. The full state
 * machine (syncSidenavAndCtas, updateNavSlider on view change, sparkle-click →
 * generation, .is-swapped/.current/.nav-pending toggling) is wired by the page
 * script when create-resources is assembled. The loading skeleton is deferred
 * with that loading flow.
 */
import Button from "./Button.astro";
---

<aside class="sidenav">
  <!-- Loading skeleton (shown while not .loaded; styled in create-resources.css) -->
  <div class="nav-skeleton" aria-hidden="true">
    <div class="skel-bar"></div>
    <div class="skel-bar"></div>
    <div class="skel-bar"></div>
    <div class="skel-bar"></div>
  </div>

  <div class="nav-slider" id="navSlider" aria-hidden="true"></div>

  <div class="sidenav-active ml-active" id="navMiniLesson">
    <span class="label">Mini Lesson</span>
  </div>

  <div class="subnav-item" id="navStudentMaterials" data-material="worksheet">
    <div class="content">
      <span class="text">Student Materials</span>
      <Button
        class="sparkle-btn"
        variant="icon"
        size="xs"
        icon="link-sparkle"
        swapIcon="arrows-rotate-reverse-btn"
        iconSize={12}
        aria-label="Recreate"
      />
    </div>
  </div>

  <div class="subnav-item" id="navSampleScript" data-material="sampleScript">
    <div class="content">
      <span class="text">Sample Script</span>
      <Button
        class="sparkle-btn"
        variant="icon"
        size="xs"
        icon="link-sparkle"
        swapIcon="arrows-rotate-reverse-btn"
        iconSize={12}
        aria-label="Recreate"
      />
    </div>
  </div>

  <div class="coming-soon">
    <span class="label">Problem Set</span>
    <span class="tag">Coming Soon</span>
  </div>
</aside>

<style>
  .sidenav {
    width: 214px;
    flex: none;
    background: var(--white);
    border-radius: 4px;
    box-shadow: var(--card-dropshadow);
    padding: 16px 7px 8px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    overflow: hidden;
    position: relative;
  }

  /* The purple highlight is one element the script slides to the active item;
     it provides the active row's background. */
  .nav-slider {
    position: absolute;
    left: 7px;
    right: 7px;
    background: var(--purple-5);
    opacity: 0;
    pointer-events: none;
    z-index: 0;
    transition:
      top 0.22s cubic-bezier(0.4, 0, 0.2, 1),
      height 0.22s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.15s ease;
  }

  .sidenav-active {
    width: 100%;
    border-left: 4px solid transparent;
    border-bottom: 1px solid var(--gray-15);
    padding: 12px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    position: relative;
    z-index: 1;
    cursor: pointer;
    transition: border-left-color 0.2s ease;
  }
  .sidenav-active:hover {
    background: var(--purple-5);
  }
  .sidenav-active.ml-active {
    border-left-color: var(--fuchsia-45);
  }
  .sidenav-active .label {
    font-size: 18px;
    font-weight: 400;
    line-height: 24px;
    color: var(--black);
    white-space: nowrap;
  }
  .sidenav-active.ml-active .label {
    font-weight: 600;
  }

  .subnav-item {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    box-sizing: border-box;
    position: relative;
    z-index: 1;
    cursor: pointer;
    transition: background 0.2s ease;
  }
  .subnav-item .content {
    /* padding-right 8px insets the sparkle button (was a button margin) */
    padding: 12px 8px 12px 28px;
    width: 100%;
    box-sizing: border-box;
    border-bottom: 1px solid var(--gray-15);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .subnav-item .text {
    font-size: 16px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--black);
    white-space: nowrap;
  }

  /* "Current view" indicator: short fuchsia bar, fades in when current/pending. */
  .subnav-item::before {
    content: "";
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    width: 4px;
    height: 24px;
    background: var(--fuchsia-45);
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .subnav-item.current::before,
  .subnav-item.nav-pending::before {
    opacity: 1;
  }
  .subnav-item.current .text,
  .subnav-item.nav-pending .text {
    font-weight: 600;
  }
  /* hover overlay (backgrounds otherwise handled by .nav-slider) */
  .subnav-item::after {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--purple-5);
    opacity: 0;
    pointer-events: none;
    z-index: -1;
    transition: opacity 0.15s ease;
  }
  .subnav-item:hover::after {
    opacity: 1;
  }

  .coming-soon {
    width: 100%;
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }
  .coming-soon .label {
    font-size: 16px;
    font-weight: 600;
    line-height: 24px;
    color: var(--gray-75);
    white-space: nowrap;
  }
  .coming-soon .tag {
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    color: var(--gray-60);
    white-space: nowrap;
  }
</style>
