---
/**
 * Are You Sure modal (Figma 17776:8320). Shown before a RECREATE. Narrower card
 * (470px). Footer: secondary CANCEL + primary RECREATE (sparkle). Body carries
 * the "Don't show this again." checkbox (#aysDontShow) — its in-memory
 * skipAysModal wiring lives in the page script.
 */
import Modal from "./Modal.astro";
import Button from "./Button.astro";

interface Props {
  id?: string;
}
const { id = "aysModal" } = Astro.props;
---

<Modal id={id} title="Are you sure?">
  <div class="ays-stack">
    <p class="modal-msg">This BETA version does not save your documents.</p>
    <label class="ays-dontshow">
      <input type="checkbox" id="aysDontShow" />
      Don't show this again.
    </label>
  </div>
  <Fragment slot="footer">
    <Button variant="secondary" size="md" id="aysCancel" label="Cancel" />
    <Button variant="primary" size="md" icon="modal-sparkles-white" id="aysRecreate" label="Recreate" />
  </Fragment>
</Modal>
