---
/**
 * Modal — generic shell shared by the prototype's byg/ays modals (and future
 * ones). Structure ported 1:1: full-screen overlay (70% black) → white card with
 * a top stripe → close-X → body (uppercase title + content) → optional footer.
 *
 * Behavior lives in src/scripts/modal.ts (wireModal). Wire it from the page
 * script: `const m = wireModal("#myModalId"); trigger.addEventListener("click", m.open)`.
 *
 * Props:
 *   id          required; the overlay element id (wireModal selector + a11y label).
 *   title       uppercase heading text.
 *   stripeColor top-stripe color; defaults to aqua-40 (#1CC7E6) per the prototype.
 *   width       card width; defaults to 600px.
 *
 * Slots: default = body content; "footer" = footer buttons (pass multiple via
 *   <Fragment slot="footer">…</Fragment> so the footer's flex gap applies).
 */
import Icon from "./Icon.astro";

interface Props {
  id: string;
  title: string;
  stripeColor?: string;
  width?: number | string;
  class?: string;
}

const {
  id,
  title,
  stripeColor = "var(--aqua-40)",
  width = 600,
  class: className,
} = Astro.props;

const titleId = `${id}Title`;
const w = typeof width === "number" ? `${width}px` : width;
const hasFooter = Astro.slots.has("footer");
---

<div
  class:list={["modal-overlay", className]}
  id={id}
  role="dialog"
  aria-modal="true"
  aria-labelledby={titleId}
  hidden
>
  <div class="modal-card" role="document" style={`--modal-stripe:${stripeColor};--modal-width:${w};`}>
    <button class="modal-close" type="button" aria-label="Close">
      <Icon name="modal-close-x" size={24} />
    </button>

    <div class="modal-body">
      <h2 class="modal-title" id={titleId}>{title}</h2>
      <slot />
    </div>

    {hasFooter && (
      <div class="modal-buttons"><slot name="footer" /></div>
    )}
  </div>
</div>

<style>
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 24px;
  }
  .modal-overlay.open {
    display: flex;
  }

  .modal-card {
    position: relative;
    background: var(--white);
    border-top: 16px solid var(--modal-stripe);
    border-radius: 4px;
    box-shadow: 1px 1px 1.5px rgba(128, 128, 128, 0.5);
    width: var(--modal-width);
    max-width: 100%;
    padding: 0 64px;
    color: var(--charcoal-95);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .modal-close {
    position: absolute;
    top: 20px;
    right: 16px;
    width: 24px;
    height: 24px;
    padding: 0;
    background: transparent;
    border: none;
    cursor: pointer;
    line-height: 0;
    color: var(--charcoal-90); /* modal-close-x is currentColor (was #414C52) */
  }

  /* 64px top (under the stripe) + 64px before the footer rule — matches the
     prototype's body-padding-top + msg-margin-bottom rhythm. */
  .modal-body {
    padding: 64px 0;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .modal-title {
    margin: 0 0 24px;
    font-size: 22px;
    font-weight: 400;
    line-height: 1.5;
    color: var(--charcoal-95);
    text-transform: uppercase;
    text-align: center;
  }

  .modal-buttons {
    width: 100%;
    border-top: 1px solid var(--gray-30);
    padding: 32px 0;
    display: flex;
    gap: 16px;
    align-items: center;
    justify-content: center;
  }
</style>
