---
import "../styles/tokens.css";
import "../styles/styles.css";

interface Props {
  title?: string;
  /** Page-scope class on <body> so page/component rules that share generic
   *  class names (.page-area, .top-nav, .modal-card, …) stay isolated now that
   *  the CSS is global. Pages pass "page-tower-alerts" / "page-create-resources". */
  bodyClass?: string;
}
const { title = "Zearn AI Targeted Materials", bodyClass } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Keep the prototype out of search results. This is a project page under a
        shared domain (zearn.github.io), so a subpath robots.txt is ignored by
        crawlers — a per-page noindex meta is the path-independent way to do it. */}
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
  </head>
  <body class={bodyClass}>
    <slot />
  </body>
</html>
