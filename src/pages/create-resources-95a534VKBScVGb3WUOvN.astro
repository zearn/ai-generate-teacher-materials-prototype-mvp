                <path class="sparkle-2" d="M55.8561 122.284C55.8139 121.66 55.408 121.123 54.8285 120.904C54.2489 120.686 53.5893 120.821 53.1454 121.262C53.1454 121.262 48.6262 128.1 44.1292 130.137C39.6322 132.174 31.5085 131.045 31.5085 131.045C30.8712 131.093 30.3338 131.499 30.1153 132.078C29.8968 132.657 30.0324 133.317 30.4736 133.761C30.4736 133.761 37.3194 138.278 39.3516 142.777C41.3838 147.276 40.2623 155.395 40.2623 155.395C40.3044 156.02 40.7103 156.557 41.2899 156.776C41.8694 156.994 42.5291 156.859 42.973 156.418C42.973 156.418 47.4922 149.58 51.9892 147.543C56.4862 145.506 64.6099 146.635 64.6099 146.635C65.2343 146.593 65.7717 146.187 65.9902 145.607C66.2087 145.028 66.0731 144.368 65.6319 143.925C65.6319 143.925 58.786 139.408 56.7538 134.909C54.7216 130.409 55.8432 122.29 55.8432 122.29L55.8561 122.284Z" />
                <path class="sparkle-3" d="M113.195 115.97C113.181 115.658 112.984 115.385 112.696 115.269C112.409 115.154 112.078 115.215 111.851 115.43C111.851 115.43 109.519 118.8 107.249 119.77C104.979 120.74 100.93 120.089 100.93 120.089C100.611 120.106 100.338 120.303 100.223 120.59C100.107 120.878 100.168 121.209 100.384 121.435C100.384 121.435 103.758 123.767 104.725 126.037C105.693 128.308 105.046 132.355 105.046 132.355C105.06 132.668 105.257 132.94 105.544 133.056C105.832 133.171 106.163 133.111 106.39 132.895C106.39 132.895 108.722 129.525 110.992 128.555C113.262 127.585 117.31 128.236 117.31 128.236C117.623 128.222 117.896 128.025 118.011 127.738C118.127 127.45 118.066 127.119 117.85 126.893C117.85 126.893 114.477 124.561 113.509 122.291C112.541 120.02 113.189 115.973 113.189 115.973L113.195 115.97Z" />
              </svg>
            </div>
          </div>

          <div class="material-section" id="section-miniLesson">
            <img class="lesson-preview" id="lessonPreviewMiniLesson" alt="Mini Lesson preview" />
          </div>

          <div class="material-section" id="section-worksheet">
            <img class="lesson-preview" id="lessonPreviewWorksheet" alt="Student Materials preview" />
            <div class="pdf-cta" data-material="worksheet">
              <div class="pdf-cta-frame">
                <div class="pdf-cta-content">
                  <span class="pdf-cta-icon"><Icon name="cta-sparkle-big" /></span>
                  <div class="pdf-cta-text">
                    <div class="pdf-cta-title">Student Materials</div>
                    <div class="pdf-cta-desc">Create a student handout with space for handwritten work.</div>
                  </div>
                </div>
                <Button variant="secondary" size="cta" icon="cta-sparkle-btn" iconSize={16} id="ctaStudentMaterials" label="Create" />
              </div>
            </div>
          </div>

          <div class="material-section" id="section-sampleScript">
            <img class="lesson-preview" id="lessonPreviewSampleScript" alt="Sample Script preview" />
            <div class="pdf-cta" data-material="sampleScript">
              <div class="pdf-cta-frame">
                <div class="pdf-cta-content">
                  <span class="pdf-cta-icon"><Icon name="cta-sparkle-big" /></span>
                  <div class="pdf-cta-text">
                    <div class="pdf-cta-title">Sample Script</div>
                    <div class="pdf-cta-desc">Create a ready to use teaching script to guide your lesson delivery.</div>
                  </div>
                </div>
                <Button variant="secondary" size="cta" icon="cta-sparkle-btn" iconSize={16} id="ctaSampleScript" label="Create" />
              </div>
            </div>
          </div>

          <!-- Inline loader for material generation; the script moves it into the
               target section while loading-worksheet / loading-samplescript. -->
          <div class="new-material-loading" id="newMaterialLoading" aria-live="polite">
            <p class="loading-message"></p>
            <div class="sparkle-anim" aria-hidden="true">
              <svg width="130.447" height="163.54" viewBox="0 0 130.447 163.54" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
                <path class="sparkle-1" d="M18.0586 77.7495C16.8577 78.9079 16.4591 80.659 17.0089 82.2164C17.5587 83.7739 18.9683 84.8866 20.6304 85.0344C20.6304 85.0344 42.3406 82.5046 54.2202 88.1777C66.0998 93.8508 77.7539 112.358 77.7539 112.358C78.9463 113.576 80.697 113.975 82.2541 113.425C83.8111 112.876 84.9234 111.466 85.0708 109.804C85.0708 109.804 82.5229 88.0814 88.2081 76.2075C93.8932 64.3337 112.38 52.6731 112.38 52.6731C113.581 51.5146 113.98 49.7636 113.43 48.2061C112.88 46.6486 111.47 45.5359 109.808 45.3882C109.808 45.3882 88.0981 47.9179 76.2185 42.2448C64.3389 36.5717 52.6849 18.064 52.6849 18.064C51.5264 16.8627 49.7757 16.4637 48.2186 17.0134C46.6616 17.5631 45.5493 18.9727 45.4018 20.6351C45.4018 20.6351 47.9498 42.3574 42.2646 54.2312C36.5795 66.105 18.0926 77.7657 18.0926 77.7657L18.0586 77.7495Z" />
                <path class="sparkle-2" d="M55.8561 122.284C55.8139 121.66 55.408 121.123 54.8285 120.904C54.2489 120.686 53.5893 120.821 53.1454 121.262C53.1454 121.262 48.6262 128.1 44.1292 130.137C39.6322 132.174 31.5085 131.045 31.5085 131.045C30.8712 131.093 30.3338 131.499 30.1153 132.078C29.8968 132.657 30.0324 133.317 30.4736 133.761C30.4736 133.761 37.3194 138.278 39.3516 142.777C41.3838 147.276 40.2623 155.395 40.2623 155.395C40.3044 156.02 40.7103 156.557 41.2899 156.776C41.8694 156.994 42.5291 156.859 42.973 156.418C42.973 156.418 47.4922 149.58 51.9892 147.543C56.4862 145.506 64.6099 146.635 64.6099 146.635C65.2343 146.593 65.7717 146.187 65.9902 145.607C66.2087 145.028 66.0731 144.368 65.6319 143.925C65.6319 143.925 58.786 139.408 56.7538 134.909C54.7216 130.409 55.8432 122.29 55.8432 122.29L55.8561 122.284Z" />
                <path class="sparkle-3" d="M113.195 115.97C113.181 115.658 112.984 115.385 112.696 115.269C112.409 115.154 112.078 115.215 111.851 115.43C111.851 115.43 109.519 118.8 107.249 119.77C104.979 120.74 100.93 120.089 100.93 120.089C100.611 120.106 100.338 120.303 100.223 120.59C100.107 120.878 100.168 121.209 100.384 121.435C100.384 121.435 103.758 123.767 104.725 126.037C105.693 128.308 105.046 132.355 105.046 132.355C105.06 132.668 105.257 132.94 105.544 133.056C105.832 133.171 106.163 133.111 106.39 132.895C106.39 132.895 108.722 129.525 110.992 128.555C113.262 127.585 117.31 128.236 117.31 128.236C117.623 128.222 117.896 128.025 118.011 127.738C118.127 127.45 118.066 127.119 117.85 126.893C117.85 126.893 114.477 124.561 113.509 122.291C112.541 120.02 113.189 115.973 113.189 115.973L113.195 115.97Z" />
              </svg>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>

  <BeforeYouGoModal />
  <AreYouSureModal />
</BaseLayout>

<script>
  import "../scripts/create-resources.ts";
</script>
