---
/**
 * AI Targeted Materials page.
 *
 * PHASE 1 (this): static loaded state — chrome + disclaimer + sidenav + main
 * column with the page-area showing a mini lesson at rest and the two CTA
 * cards. No state machine yet.
 *
 * PHASE 2 (next): the shuffle-bag + state machine in src/scripts/create-resources.ts
 * — random unique mini-lesson cycle, on-demand generation of aligned student
 * materials / sample script (random 1-of-N, A1↔A2 toggle on recreate), the 9s
 * (currently 3s) loading flow, recreate (ays) + back (byg) modal wiring, sidenav
 * sync, print. Reset-to-ungenerated when the mini lesson is recreated.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import TopNavAI from "../components/TopNavAI.astro";
import SubNavAI from "../components/SubNavAI.astro";
import SideNavAI from "../components/SideNavAI.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import BeforeYouGoModal from "../components/BeforeYouGoModal.astro";
import AreYouSureModal from "../components/AreYouSureModal.astro";

// The mini lesson + timestamp are set by create-resources.ts after the loading
// animation (shuffle bag). studentName is a placeholder until ?student= (2d).
const studentName = "Elijah Park";
const generatedAt = "Generated April 6, 2026 - 3:52pm";
---

<BaseLayout title="Zearn AI Targeted Materials" bodyClass="page-create-resources">
  <div class="header-wrap">
    <TopNavAI />
    <SubNavAI studentName={studentName} />
  </div>

  <main class="content-wrap">
    <div class="disclaimer">
      Reminder: AI can make mistakes! Review this content for accuracy. We do not
      use student data with generative AI.&nbsp;
      <a href="#">View Zearn's AI data policy.</a>
    </div>

    <div class="side-by-side">
      <SideNavAI />

      <div class="main-col">
        <div class="button-group">
          <span class="generated" id="generatedTimestamp">{generatedAt}</span>
          <div class="btn-cluster">
            <Button variant="secondary" size="sm" icon="arrows-rotate-reverse-btn" iconSize={16} id="recreateBtn" label="Recreate" />
            <Button variant="icon" size="sm" icon="print-btn" iconSize={17} aria-label="Print" />
          </div>
        </div>

        <section class="page-area">
          <!-- Loading overlay (covers the area until .loaded; the script renders the mini lesson after) -->
          <div class="loading-content" aria-live="polite">
            <p class="loading-message">Zearn AI is creating materials for your student right now.</p>
            <div class="sparkle-anim" aria-hidden="true">
              <svg width="130.447" height="163.54" viewBox="0 0 130.447 163.54" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
