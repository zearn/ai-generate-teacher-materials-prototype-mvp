---

<BaseLayout title="Tower Alerts — Zearn" bodyClass="page-tower-alerts hide-completed">
  <div class="header-wrap">
    <nav class="top-nav">
      <div class="nav">
        <div class="left">
          <span class="logo-wrap"><Icon name="zearn-logo" /></span>
          <button class="top-tab">CURRICULUM</button>
          <button class="top-tab active">REPORTS</button>
        </div>
        <div class="right">
          <a class="link link-assignments" href="#">Assignments</a>
          <a class="link link-roster" href="#">Roster</a>
          <a class="link link-resources" href="#">Resources</a>
          <a class="link link-help" href="#" aria-label="Help (opens in a new tab)">
            Help<Icon name="open-new-tab" />
          </a>
          <div class="account-box">
            <span class="school-chip">School<br />Account</span>
            <span class="account-name">Ahmed</span>
            <span class="caret"><Icon name="chevron-down-name" /></span>
          </div>
        </div>
      </div>
    </nav>
    <div class="yellow-bar"></div>

    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li>
          <a class="crumb-link" href="#">Reports</a>
          <span class="crumb-sep" aria-hidden="true"><Icon name="chevron-right-bc" /></span>
        </li>
        <li>
          <a class="crumb-link" href="#">Class Reports</a>
          <span class="crumb-sep" aria-hidden="true"><Icon name="chevron-right-bc" /></span>
        </li>
        <li>
          <button class="crumb-select" aria-haspopup="true">
            Tower Alerts
            <span class="caret"><Icon name="chevron-down-tower" /></span>
          </button>
        </li>
      </ol>
    </nav>
  </div>

  <div class="page-area">
    <main>
      <section class="page-header">
        <h1>
          Tower Alerts
          <span class="help-link" id="helpIcon" tabindex="0" data-tip="An alert is triggered when a student struggles repeatedly on the same concept in a tower.">
            <Icon name="help-circle" title="Help" />
          </span>
        </h1>
        <p class="subtitle">An alert is triggered when a student struggles repeatedly on the same concept in a tower.</p>
      </section>

      <section class="selector">
        <button class="pill">
          Kleinfeldt - Grade 4
          <span class="caret" aria-hidden="true"><Icon name="chevron-small-down" /></span>
        </button>
      </section>

      <section class="hero">
        <div class="left">
          <span class="icon"><Icon name="purple-people" size={72} /></span>
          <div>
            <h2>Kleinfeldt - Grade 4</h2>
            <div class="meta">Grade 4 | 25 Students</div>
          </div>
        </div>
        <button class="print-btn"><Icon name="print" /> Print</button>
      </section>

      <div class="columns">

        <!-- LEFT: Filter sidebar -->
        <aside>
          <div class="filter-header"><span>Filter by</span></div>

          <div class="filter-box">
            <div class="filter-row">
              <label>Completed Towers</label>
              <div class="toggle off" id="completedToggle" role="switch" aria-checked="false">
                <span class="label-hide">Hide</span>
                <span class="switch" tabindex="0">
                  <span class="track"></span>
                  <span class="knob"></span>
                </span>
                <span class="label-show">Show</span>
              </div>
            </div>

            <div class="filter-row">
              <label for="dateFilter">Date</label>
              <div class="dropdown">
                <select id="dateFilter">
                  <option>All</option>
                  <option selected>Past Week</option>
                  <option>Past 2 Weeks</option>
                  <option>Past 3 Weeks</option>
                  <option>Past Month</option>
                  <option>Past 6 Months</option>
                </select>
                <span class="caret"><Icon name="chevron-down-dropdown" size={24} /></span>
              </div>
            </div>

            <div class="filter-row">
              <label for="strugglesFilter">Struggles</label>
              <div class="dropdown">
                <select id="strugglesFilter">
                  <option selected>1 or more</option>
                  <option>2 or more</option>
                  <option>3 or more</option>
                </select>
                <span class="caret"><Icon name="chevron-down-dropdown" size={24} /></span>
              </div>
            </div>
          </div>

          <!-- Students panel -->
          <div class="panel" id="studentsPanel">
            <button class="panel-header" data-toggle="studentsPanel">
              Students
              <span class="chev" aria-hidden="true"><Icon name="chevron-up-students" size={16} /></span>
            </button>
            <div class="list" id="studentList">
              <div class="row selected"><span>ALL</span><span class="count">30&nbsp;Results</span></div>
              {STUDENTS.map(s => (
                <div class={`row ${s.count > 0 ? 'semibold' : 'regular'}`}>
                  <span>{s.name}</span>
                  {s.count > 0 && <span class="count">{s.count}</span>}
                </div>
              ))}
            </div>
          </div>

          <!-- Content panel -->
          <div class="panel" id="contentPanel">
            <button class="panel-header" data-toggle="contentPanel">
              Content
              <span class="chev" aria-hidden="true"><Icon name="chevron-up-content" size={16} /></span>
            </button>
            <div class="list content-list" id="contentList">
              <div class="row selected">
                <span class="label-wrap"><span>ALL</span><span class="count">30&nbsp;Results</span></span>
              </div>
              {GRADES.map(g => (
                <div class={`row ${g.count != null ? 'semibold' : 'regular'}`}>
                  <span class="twirl"><Icon name="chevron-right-grade" size={16} /></span>
                  <span class="label-wrap">
                    <span>{g.name}</span>
                    {g.count != null && <span class="count">{g.count}</span>}
                  </span>
                </div>
              ))}
            </div>
          </div>
        </aside>

        <!-- RIGHT: Sort + alerts + load more -->
        <section>
          <div class="sort-row">
            <div class="sort-left">
              <span class="label">Sort by</span>
              <div class="dropdown wide lg">
                <select id="sortBy">
                  <option selected>Date: Newest</option>
                  <option>Date: Earliest</option>
                  <option>Content: Newest</option>
                  <option>Content: Earliest</option>
                </select>
                <span class="caret"><Icon name="chevron-down-dropdown" size={24} /></span>
              </div>
            </div>
            <div class="results-count"><span>30</span><span class="rest">&nbsp;Results</span></div>
          </div>

          <div class="alerts" id="alerts">
            {ALERTS.map(a => (
              <article class="alert">
                <div class="alert-icon">
                  <Icon name="tower-circle" size={48} />
                </div>
                <div class="alert-head">
                  <div class="alert-info">
                    <div class="student-row">
                      <span class="student-name">{a.student}</span>
                      <a class="student-report-link" href="#" title="View student report">
                        <Icon name="student-report-v2" size={16} />
                      </a>
                    </div>
                  </div>
                  <div class="alert-side">
                    <a class="create-resources"
                       href={`${import.meta.env.BASE_URL}/create-resources-95a534VKBScVGb3WUOvN?student=${encodeURIComponent(a.student)}&lesson=${encodeURIComponent(a.lesson)}&loc=${encodeURIComponent(a.loc)}`}
                       data-student={a.student}
                       data-lesson={a.lesson}
                       data-loc={a.loc}
                       data-desc={a.desc}>
                      <Icon name="sparkles-link" size={18} />
                      Create Targeted Materials
                    </a>
                    <span class="alert-divider"></span>
                    <span class="alert-count">{a.count}</span>
                    <span class="bang-icon">
                      <Icon name="circle-bang" size={24} />
                    </span>
                  </div>
                </div>
                <div class="breadcrumb-meta">{a.loc}</div>
                <a class="lesson-link" href="#">{a.lesson}</a>
                <div class="alert-desc">{a.desc}</div>
                <div class="sep"></div>
                {a.events.map(e => (
                  <div class={`event evt-${e.type}`}>
                    <span class="ico">
                      {e.type === "completed" ? (
                        <svg class="alert-check" viewBox="0 0 16 16" fill="currentColor">
                          <path d="M6 11.2L2.8 8 1.4 9.4 6 14l9-9-1.4-1.4z"/>
                        </svg>
                      ) : (
                        <Icon name="icon-bang" />
                      )}
                    </span>
                    <span class="label">{e.type === "completed" ? "Completed" : "Alert"}</span>
                    <span class="ts">{e.ts}</span>
                  </div>
                ))}
              </article>
            ))}
          </div>

          <div class="load-more-wrap">
            <button class="load-more">LOAD MORE</button>
          </div>
        </section>

      </div>
    </main>
  </div>

  <div class="tooltip" id="tooltip"></div>

  <CreateTargetedMaterialsModal />
</BaseLayout>

<script>
  import "../scripts/tower-alerts.ts";
</script>
